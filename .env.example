# ADgents Environment Configuration
# Copy this to .env and fill in your API keys

# ── LLM Provider API Keys ──────────────────────────────────────────────────────
# At least one is required. The system will use the first available one.

# Google Gemini (Recommended - Free tier available!)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# OpenAI (GPT-4o, GPT-4o-mini, etc.)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude
ANTHROPIC_API_KEY=your-anthropic-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Ollama (Local, No API Key Required)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# ── Default LLM Provider Selection ──────────────────────────────────────────────
# Choose which provider to use by default
# Options: gemini, openai, anthropic, ollama
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_LLM_MODEL=gemini-1.5-flash

# ── Server Configuration ────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# ── Data Storage ───────────────────────────────────────────────────────────────
DATA_DIR=./data
DB_PATH=./data/db

# ── Agent Defaults ─────────────────────────────────────────────────────────────
DEFAULT_MAX_ITERATIONS=10
DEFAULT_CREATIVITY=0.7
DEFAULT_AUTONOMY_LEVEL=3
LOG_LEVEL=INFO
